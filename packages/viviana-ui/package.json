{
  "name": "@proyecto-viviana/viviana-ui",
  "version": "0.1.2",
  "description": "Viviana design system. Starts by re-exporting @proyecto-viviana/solid-spectrum (same components + tokens + style macro); diverges (viviana tokens, then components) over time.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proyecto-viviana/ui.git",
    "directory": "packages/viviana-ui"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style": {
      "types": "./dist/style.d.ts",
      "solid": "./dist/style.js",
      "import": "./dist/style.js",
      "default": "./dist/style.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@proyecto-viviana/solid-spectrum": "workspace:*"
  },
  "devDependencies": {
    "solid-js": "^1.9.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}

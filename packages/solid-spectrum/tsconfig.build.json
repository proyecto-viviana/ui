{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@adobe/spectrum-tokens/dist/json/variables.json": [
        "./src/style/spectrum-tokens-json.d.ts"
      ],
      "@proyecto-viviana/solid-stately": ["../solid-stately/dist/index.d.ts"],
      "@proyecto-viviana/solidaria": ["../solidaria/dist/index.d.ts"],
      "@proyecto-viviana/solidaria-components": ["../solidaria-components/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "src/test-utils"]
}

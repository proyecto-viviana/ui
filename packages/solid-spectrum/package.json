{
  "name": "@proyecto-viviana/solid-spectrum",
  "version": "0.4.2",
  "description": "Spectrum 2-compatible styled components for SolidJS",
  "keywords": [
    "components",
    "design-system",
    "solid",
    "solid-spectrum",
    "solidjs",
    "spectrum-2"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proyecto-viviana/proyecto-viviana.git",
    "directory": "packages/solid-spectrum"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ActionMenu": {
      "types": "./dist/ActionMenu.d.ts",
      "solid": "./src/ActionMenu.ts",
      "import": "./dist/ActionMenu.js",
      "default": "./dist/ActionMenu.js"
    },
    "./Breadcrumbs": {
      "types": "./dist/Breadcrumbs.d.ts",
      "solid": "./src/Breadcrumbs.ts",
      "import": "./dist/Breadcrumbs.js",
      "default": "./dist/Breadcrumbs.js"
    },
    "./Calendar": {
      "types": "./dist/Calendar.d.ts",
      "solid": "./src/Calendar.ts",
      "import": "./dist/Calendar.js",
      "default": "./dist/Calendar.js"
    },
    "./ColorArea": {
      "types": "./dist/ColorArea.d.ts",
      "solid": "./src/ColorArea.ts",
      "import": "./dist/ColorArea.js",
      "default": "./dist/ColorArea.js"
    },
    "./ColorField": {
      "types": "./dist/ColorField.d.ts",
      "solid": "./src/ColorField.ts",
      "import": "./dist/ColorField.js",
      "default": "./dist/ColorField.js"
    },
    "./ColorSlider": {
      "types": "./dist/ColorSlider.d.ts",
      "solid": "./src/ColorSlider.ts",
      "import": "./dist/ColorSlider.js",
      "default": "./dist/ColorSlider.js"
    },
    "./ColorSwatch": {
      "types": "./dist/ColorSwatch.d.ts",
      "solid": "./src/ColorSwatch.ts",
      "import": "./dist/ColorSwatch.js",
      "default": "./dist/ColorSwatch.js"
    },
    "./ColorSwatchPicker": {
      "types": "./dist/ColorSwatchPicker.d.ts",
      "solid": "./src/ColorSwatchPicker.ts",
      "import": "./dist/ColorSwatchPicker.js",
      "default": "./dist/ColorSwatchPicker.js"
    },
    "./ColorWheel": {
      "types": "./dist/ColorWheel.d.ts",
      "solid": "./src/ColorWheel.ts",
      "import": "./dist/ColorWheel.js",
      "default": "./dist/ColorWheel.js"
    },
    "./Disclosure": {
      "types": "./dist/disclosure-export.d.ts",
      "solid": "./src/disclosure-export.ts",
      "import": "./dist/disclosure-export.js",
      "default": "./dist/disclosure-export.js"
    },
    "./Card": {
      "types": "./dist/Card.d.ts",
      "solid": "./src/Card.ts",
      "import": "./dist/Card.js",
      "default": "./dist/Card.js"
    },
    "./CardView": {
      "types": "./dist/CardView.d.ts",
      "solid": "./src/CardView.ts",
      "import": "./dist/CardView.js",
      "default": "./dist/CardView.js"
    },
    "./ListView": {
      "types": "./dist/ListView.d.ts",
      "solid": "./src/ListView.ts",
      "import": "./dist/ListView.js",
      "default": "./dist/ListView.js"
    },
    "./RangeCalendar": {
      "types": "./dist/RangeCalendar.d.ts",
      "solid": "./src/RangeCalendar.ts",
      "import": "./dist/RangeCalendar.js",
      "default": "./dist/RangeCalendar.js"
    },
    "./Tabs": {
      "types": "./dist/Tabs.d.ts",
      "solid": "./src/Tabs.ts",
      "import": "./dist/Tabs.js",
      "default": "./dist/Tabs.js"
    },
    "./Menu": {
      "types": "./dist/Menu.d.ts",
      "solid": "./src/Menu.ts",
      "import": "./dist/Menu.js",
      "default": "./dist/Menu.js"
    },
    "./theme.css": {
      "import": "./dist/theme.css",
      "default": "./src/theme.css"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "default": "./src/styles.css"
    },
    "./components.css": {
      "import": "./dist/components.css",
      "default": "./src/components.css"
    },
    "./style": {
      "types": "./dist/style/index.d.ts",
      "solid": "./src/style/index.ts",
      "import": "./dist/style/index.js",
      "default": "./dist/style/index.js"
    },
    "./style/runtime": {
      "types": "./dist/style/runtime.d.ts",
      "solid": "./src/style/runtime.ts",
      "import": "./dist/style/runtime.js",
      "default": "./dist/style/runtime.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ../../scripts/generate-solid-spectrum-s2-css.ts && vp fmt src/s2-generated.css --write && vp pack && rm -f tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "dev": "vp pack --watch",
    "prepublishOnly": "echo 'Use the root Changesets npm release workflow'"
  },
  "dependencies": {
    "@adobe/spectrum-tokens": "^14.5.0",
    "@proyecto-viviana/solid-stately": "workspace:*",
    "@proyecto-viviana/solidaria": "workspace:*",
    "@proyecto-viviana/solidaria-components": "workspace:*",
    "csstype": "^3.2.3"
  },
  "devDependencies": {
    "@proyecto-viviana/solid-spectrum-test-utils": "workspace:*",
    "solid-js": "^1.9.11"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  }
}

---
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";
import { getDocsTocItems, type DocsTocItem, type DocsTocVariant } from "@comparison/data/docs-toc";
import {
  docsTocActions,
  docsTocDivider,
  docsTocHeading,
  docsTocIndicator,
  docsTocLink,
  docsTocLinkText,
  docsTocList,
  docsTocListItem,
  docsTocNav,
  docsTocScroller,
  staticClassName,
} from "./solid/chrome/styles";

export interface Props {
  entry?: ComparisonEntry;
  items?: DocsTocItem[];
  sourceLabel?: string;
  sourceUrl?: string;
  variant: DocsTocVariant;
}

const { entry, items, sourceLabel, sourceUrl, variant } = Astro.props;
const tocNavClass = staticClassName(docsTocNav);
const tocHeadingClass = staticClassName(docsTocHeading);
const tocLinkClass = staticClassName(docsTocLink);
const tocIndicatorClass = staticClassName(docsTocIndicator);
const tocLinkTextClass = staticClassName(docsTocLinkText);
const tocListClass = staticClassName(docsTocList);
const tocListItemClass = staticClassName(docsTocListItem);
const tocActionsClass = staticClassName(docsTocActions);
const tocDividerClass = staticClassName(docsTocDivider);
const tocScrollerClass = staticClassName(docsTocScroller);

const tocItems = getDocsTocItems({ entry, items, variant });
---

<div data-docs-toc-fallback>
  <div class={tocHeadingClass}>On this page</div>
  <div class={tocScrollerClass}>
    <nav class={tocNavClass} aria-label="On this page">
      <ul class={tocListClass}>
        {tocItems.map((item) => (
          <li
            class={tocListItemClass}
            style={item.depth && item.depth > 2 ? `padding-inline-start: ${(item.depth - 2) * 12}px` : undefined}
          >
            <a href={item.href} class={tocLinkClass}>
              <span aria-hidden="true" class={tocIndicatorClass}></span>
              <span class={tocLinkTextClass}>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  {sourceUrl ? (
    <div class={tocActionsClass}>
      <hr class={tocDividerClass} />
      <a href={sourceUrl} class={tocLinkClass}>
        <span aria-hidden="true" class={tocIndicatorClass}></span>
        <span class={tocLinkTextClass}>{sourceLabel ?? "S2 source"}</span>
      </a>
    </div>
  ) : null}
</div>

---
import { comparisonEntries, type ComparisonSlug } from "@comparison/data/comparison-manifest";
import {
  docsNavIndicator,
  docsNavIndicatorCurrent,
  docsNavItem,
  docsNavLink,
  docsNavLinkCurrent,
  docsNavLinkText,
  docsNavList,
  docsNavRoot,
  docsNavSection,
  docsNavSectionPanelInner,
  docsNavSectionSummary,
  staticClassName,
} from "./solid/chrome/styles";

export interface Props {
  activeSlug?: string;
  navigationLabel?: string;
  referenceLabel?: string;
  referenceUrl?: string;
}

const { activeSlug, navigationLabel } = Astro.props;
const normalizedActiveSlug = comparisonEntries.some((entry) => entry.slug === activeSlug)
  ? (activeSlug as ComparisonSlug)
  : undefined;
const navRootClass = staticClassName(docsNavRoot);
const navSectionClass = staticClassName(docsNavSection);
const navSectionSummaryClass = staticClassName(docsNavSectionSummary);
const navSectionPanelInnerClass = staticClassName(docsNavSectionPanelInner);
const navListClass = staticClassName(docsNavList);
const navItemClass = staticClassName(docsNavItem);
const navLinkClass = staticClassName(docsNavLink);
const navLinkCurrentClass = staticClassName(docsNavLinkCurrent);
const navLinkTextClass = staticClassName(docsNavLinkText);
const navIndicatorClass = staticClassName(docsNavIndicator);
const navIndicatorCurrentClass = staticClassName(docsNavIndicatorCurrent);
---

<nav class:list={["s2-nav", navRootClass]} aria-label={navigationLabel ?? "Documentation"}>
  <details class:list={["s2-nav-section", navSectionClass]} open>
    <summary class:list={["s2-nav-section-summary", navSectionSummaryClass]}>
      Components
    </summary>
    <div class={navSectionPanelInnerClass}>
      <ul class:list={["s2-nav-list", navListClass]}>
        {comparisonEntries.map((item) => (
          <li class={navItemClass}>
            <a
              href={`/components/${item.slug}`}
              class:list={["s2-nav-link", navLinkClass, item.slug === normalizedActiveSlug && navLinkCurrentClass]}
              aria-current={item.slug === normalizedActiveSlug ? "page" : undefined}
            >
              <span
                aria-hidden="true"
                class:list={[
                  "s2-nav-link-indicator",
                  navIndicatorClass,
                  item.slug === normalizedActiveSlug && navIndicatorCurrentClass,
                ]}
              />
              <span class={navLinkTextClass}>{item.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </details>
</nav>

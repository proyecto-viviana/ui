---
import DocsTocFallback from "./DocsTocFallback.astro";
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";
import type { DocsTocItem, DocsTocVariant } from "@comparison/data/docs-toc";
import { docsChromeMount, docsTocMount, staticClassName } from "./solid/chrome/styles";

export interface Props {
  entry?: ComparisonEntry;
  items?: DocsTocItem[];
  sourceLabel?: string;
  sourceUrl?: string;
  variant: DocsTocVariant;
}

const { entry, items, sourceLabel, sourceUrl, variant } = Astro.props;
const chromeMountClass = staticClassName(docsChromeMount);
const tocMountClass = staticClassName(docsTocMount);
const serializedItems = items && items.length > 0 ? JSON.stringify(items) : "";
---

<div
  class:list={["js-docs-toc-mount", chromeMountClass, tocMountClass]}
  data-component-slug={entry?.slug ?? ""}
  data-source-label={sourceLabel ?? "S2 source"}
  data-source-url={sourceUrl ?? ""}
  data-toc-items={serializedItems}
  data-variant={variant}
>
  <DocsTocFallback
    entry={entry}
    items={items}
    sourceLabel={sourceLabel}
    sourceUrl={sourceUrl}
    variant={variant}
  />
</div>
<script>
  import "../scripts/docs-toc-mount.tsx";
</script>

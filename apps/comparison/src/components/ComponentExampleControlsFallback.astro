---
import { getComponentControlGroup, type ComponentControl } from "@comparison/data/component-controls";
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";

interface Props {
  entry: ComparisonEntry;
}

const { entry } = Astro.props as Props;
const controlGroup = getComponentControlGroup(entry);
const visibleControls = controlGroup.controls.filter((control) => !control.isHidden);
const hiddenControls = controlGroup.controls.filter((control) => control.isHidden);
const controlDefaults = Object.fromEntries(
  controlGroup.controls.map((control) => [control.name, control.defaultValue]),
);

function controlHelpText(control: ComponentControl): string {
  if (control.kind === "switch") {
    return `Toggles the ${control.name} boolean prop in both rendered examples.`;
  }

  if (control.kind === "text") {
    return `Controls the ${control.name} prop value in both rendered examples.`;
  }

  return `Selects the ${control.name} prop value in both rendered examples.`;
}
---

<div class="s2-component-example-controls-fallback" data-component-example-controls-fallback>
  <h2 id="example-title">Example</h2>
  {controlGroup.controls.length > 0 ? (
    <form
      class="s2-prop-controls"
      data-comparison-controls={entry.slug}
      data-control-coverage={controlGroup.coverage}
      data-control-defaults={JSON.stringify(controlDefaults)}
    >
      {hiddenControls.map((control) => (
        <input type="hidden" name={control.name} value={String(control.defaultValue)} />
      ))}
      {visibleControls.map((control) => (
        <div
          class="s2-prop-control"
          data-control-kind={control.kind}
          data-control-name={control.name}
        >
          {entry.slug === "button" && control.name === "children" ? (
            <div class="s2-inline-control-row">
              <div class="s2-field s2-inline-control-text">
                <span class="s2-control-label">
                  <span class="s2-control-label-text">{control.label}</span>
                  <button
                    type="button"
                    class="s2-control-help-button"
                    aria-label="Information"
                    title={controlHelpText(control)}
                    disabled
                  >
                    <span aria-hidden="true">i</span>
                  </button>
                </span>
                <input
                  aria-label={control.label}
                  name={control.name}
                  value={String(control.defaultValue)}
                />
              </div>
              <button
                type="button"
                class="s2-icon-choice-button s2-fallback-icon-choice-button"
                data-button-icon-control
              >
                No icon
              </button>
            </div>
          ) : control.kind === "text" ? (
            <div class="s2-field">
              <span class="s2-control-label">
                <span class="s2-control-label-text">{control.label}</span>
                <button
                  type="button"
                  class="s2-control-help-button"
                  aria-label="Information"
                  title={controlHelpText(control)}
                  disabled
                >
                  <span aria-hidden="true">i</span>
                </button>
              </span>
              <input
                aria-label={control.label}
                name={control.name}
                value={String(control.defaultValue)}
              />
            </div>
          ) : control.kind === "select" ? (
            <div class="s2-field">
              <span class="s2-control-label">
                <span class="s2-control-label-text">{control.label}</span>
                <button
                  type="button"
                  class="s2-control-help-button"
                  aria-label="Information"
                  title={controlHelpText(control)}
                  disabled
                >
                  <span aria-hidden="true">i</span>
                </button>
              </span>
              <select aria-label={control.label} name={control.name}>
                {control.options?.map((option) => (
                  <option value={option.value} selected={option.value === control.defaultValue}>
                    {option.label}
                  </option>
                ))}
              </select>
            </div>
          ) : control.kind === "radio" ? (
            <fieldset class="s2-radio-group">
              <legend>
                <span class="s2-control-label">
                  <span class="s2-control-label-text">{control.label}</span>
                  <button
                    type="button"
                    class="s2-control-help-button"
                    aria-label="Information"
                    title={controlHelpText(control)}
                    disabled
                  >
                    <span aria-hidden="true">i</span>
                  </button>
                </span>
              </legend>
              <div>
                {control.options?.map((option) => (
                  <label>
                    <input
                      type="radio"
                      name={control.name}
                      value={option.value}
                      checked={option.value === control.defaultValue}
                    />
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          ) : (
            <div class="s2-switch-control-stack">
              <span class="s2-control-label">
                <span class="s2-control-label-text">{control.label}</span>
                <button
                  type="button"
                  class="s2-control-help-button"
                  aria-label="Information"
                  title={controlHelpText(control)}
                  disabled
                >
                  <span aria-hidden="true">i</span>
                </button>
              </span>
              <label class="s2-switch s2-fallback-switch-control">
                <input
                  aria-label={control.label}
                  name={control.name}
                  type="checkbox"
                  checked={control.defaultValue === true}
                />
              </label>
            </div>
          )}
        </div>
      ))}
    </form>
  ) : (
    <div class="s2-empty-state">Interactive S2 prop controls are missing for this component.</div>
  )}
</div>

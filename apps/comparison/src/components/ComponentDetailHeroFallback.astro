---
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";

interface Props {
  entry: ComparisonEntry;
}

const { entry } = Astro.props as Props;
---

<section class="s2-hero" aria-labelledby="page-title" data-component-detail-hero-fallback>
  <h1 id="page-title">{entry.title}</h1>
  <p>{entry.summary}</p>
</section>

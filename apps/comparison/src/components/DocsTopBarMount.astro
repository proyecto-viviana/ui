---
import DocsTopBarFallback from "./DocsTopBarFallback.astro";
import type { DocsTocVariant } from "@comparison/data/docs-toc";

export interface Props {
  activeSlug?: string;
  navigationLabel?: string;
  reactSpectrumUrl?: string;
  referenceLabel?: string;
  referenceUrl?: string;
  tocSlug?: string;
  tocVariant?: DocsTocVariant;
}

const {
  activeSlug,
  navigationLabel,
  reactSpectrumUrl,
  referenceLabel,
  referenceUrl,
  tocSlug,
  tocVariant,
} = Astro.props;
const normalizedReactSpectrumUrl = typeof reactSpectrumUrl === "string" ? reactSpectrumUrl : "";
---

<div
  class="js-docs-topbar-mount"
  data-active-slug={activeSlug ?? ""}
  data-navigation-label={navigationLabel ?? "Documentation"}
  data-react-spectrum-url={normalizedReactSpectrumUrl}
  data-reference-label={referenceLabel ?? "S2 docs"}
  data-reference-url={referenceUrl ?? ""}
  data-toc-slug={tocSlug ?? ""}
  data-toc-variant={tocVariant ?? "index"}
>
  <DocsTopBarFallback reactSpectrumUrl={reactSpectrumUrl} />
</div>
<script>
  import "../scripts/docs-topbar-mount.tsx";
</script>

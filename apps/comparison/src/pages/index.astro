---
import {
  comparisonEntries,
  missingOfficialComparisonEntries,
  officialComparisonEntries,
} from "@comparison/data/comparison-manifest";
import { groupComparisonEntries } from "@comparison/data/component-groups";
import { getComponentControlGroup } from "@comparison/data/component-controls";
import { getComponentCoverage } from "@comparison/data/coverage";
import { reactSpectrumCatalogueSource } from "@comparison/data/react-spectrum-catalogue";
import { officialVisualStateSummary } from "@comparison/data/visual-state-matrix";
import CatalogueControlsMount from "@comparison/components/CatalogueControlsMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import "@comparison/styles/global.css";

const liveCount = comparisonEntries.filter((entry) => entry.priority === "live").length;
const officialCount = officialComparisonEntries.length;
const missingOfficialCount = missingOfficialComparisonEntries.length;
const visualEvidenceStateCount = officialVisualStateSummary.visualEvidenceStates;
const strictStateCount = officialVisualStateSummary.strictPairDiffStates;

const entriesWithCoverage = comparisonEntries.map((entry) => ({
  entry,
  coverage: getComponentCoverage(entry, getComponentControlGroup(entry)),
}));
const sidebarGroups = groupComparisonEntries(comparisonEntries);

const overallCoverage = Math.round(
  entriesWithCoverage.reduce((sum, item) => sum + item.coverage.overall, 0) /
    entriesWithCoverage.length,
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Solid Spectrum</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <DocsTopBarMount reactSpectrumUrl={reactSpectrumCatalogueSource.url} />

    <div class="s2-layout">
      <aside class="s2-sidebar">
        <nav class="s2-nav s2-nav--grouped" aria-label="Documentation">
          <p>Overview</p>
          <a href="/" aria-current="page">Getting started</a>
          <p>Components</p>
          {sidebarGroups.map((group) => (
            <details class="s2-nav-group" open>
              <summary>
                <span>{group.title}</span>
                <span>{group.entries.length}</span>
              </summary>
              <div>
                {group.entries.map((item) => (
                  <a href={`/components/${item.slug}`}>{item.title}</a>
                ))}
              </div>
            </details>
          ))}
          <p>Guides</p>
          <a href="/components/button">Visual parity</a>
          <a href="/components/button#api">API coverage</a>
          <p>Reference</p>
          <a href={reactSpectrumCatalogueSource.url}>S2 catalogue</a>
        </nav>
      </aside>

      <main class="s2-main">
        <section class="s2-hero" aria-labelledby="page-title">
          <h1 id="page-title">Solid Spectrum</h1>
          <p>
            A component-by-component parity harness for React Spectrum S2 and
            @proyecto-viviana/solid-spectrum.
          </p>
        </section>

        <section class="s2-example" aria-labelledby="coverage-title">
          <div class="s2-example-preview">
            <div class="s2-coverage-ring" style={`--value: ${overallCoverage}%`}>
              <strong>{overallCoverage}%</strong>
              <span>overall coverage</span>
            </div>
            <div class="s2-stat-grid">
              <div><span>Official S2</span><strong>{officialCount}</strong></div>
              <div><span>Live routes</span><strong>{liveCount}</strong></div>
              <div><span>Gaps</span><strong>{missingOfficialCount}</strong></div>
              <div><span>Visual evidence</span><strong>{visualEvidenceStateCount}</strong></div>
              <div><span>Strict pairs</span><strong>{strictStateCount}</strong></div>
            </div>
          </div>
          <div class="s2-example-controls">
            <h2 id="coverage-title">Catalogue controls</h2>
            <CatalogueControlsMount />
          </div>
        </section>

        <section class="s2-section" aria-labelledby="components-title">
          <div class="s2-section-heading">
            <h2 id="components-title">Components</h2>
            <span data-result-count>{comparisonEntries.length} components</span>
          </div>
          <div class="s2-component-list" data-entry-list>
            {entriesWithCoverage.map(({ entry, coverage }, index) => (
              <a
                href={`/components/${entry.slug}`}
                class="s2-component-row"
                data-entry-card
                data-index={index}
                data-title={entry.title}
                data-summary={entry.summary}
                data-parity={entry.parity}
                data-status={entry.priority}
                data-source={entry.catalogueSource}
                data-coverage={coverage.overall}
              >
                <span class="s2-component-name">{entry.title}</span>
                <span class="s2-component-summary">{entry.summary}</span>
                <span class="s2-meter" aria-label={`${coverage.overall}% coverage`}>
                  <span style={`width: ${coverage.overall}%`}></span>
                </span>
                <span class={`s2-pill s2-pill--${entry.parity}`}>{entry.parity}</span>
              </a>
            ))}
          </div>
        </section>
      </main>

      <aside class="s2-toc" aria-label="On this page">
        <p>On this page</p>
        <a href="#page-title">Solid Spectrum</a>
        <a href="#coverage-title">Catalogue controls</a>
        <a href="#components-title">Components</a>
        <div class="s2-toc-actions">
          <a href={reactSpectrumCatalogueSource.url}>S2 source</a>
        </div>
      </aside>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
    </script>
  </body>
</html>

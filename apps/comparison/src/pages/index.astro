---
import {
  comparisonEntries,
  missingOfficialComparisonEntries,
  officialComparisonEntries,
} from "@comparison/data/comparison-manifest";
import { getComponentControlGroup } from "@comparison/data/component-controls";
import { getComponentCoverage } from "@comparison/data/coverage";
import { reactSpectrumCatalogueSource } from "@comparison/data/react-spectrum-catalogue";
import { officialVisualStateSummary } from "@comparison/data/visual-state-matrix";
import CatalogueOverviewMount from "@comparison/components/CatalogueOverviewMount.astro";
import DocsSidebarMount from "@comparison/components/DocsSidebarMount.astro";
import DocsTocMount from "@comparison/components/DocsTocMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import "@comparison/styles/global.css";

const liveCount = comparisonEntries.filter((entry) => entry.priority === "live").length;
const officialCount = officialComparisonEntries.length;
const missingOfficialCount = missingOfficialComparisonEntries.length;
const visualEvidenceStateCount = officialVisualStateSummary.visualEvidenceStates;
const strictStateCount = officialVisualStateSummary.strictPairDiffStates;

const entriesWithCoverage = comparisonEntries.map((entry) => ({
  entry,
  coverage: getComponentCoverage(entry, getComponentControlGroup(entry)),
}));

const overallCoverage = Math.round(
  entriesWithCoverage.reduce((sum, item) => sum + item.coverage.overall, 0) /
    entriesWithCoverage.length,
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Solid Spectrum</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <DocsTopBarMount reactSpectrumUrl={reactSpectrumCatalogueSource.url} />

    <div class="s2-layout">
      <aside class="s2-sidebar">
        <DocsSidebarMount
          navigationLabel="Documentation"
          referenceLabel="S2 catalogue"
          referenceUrl={reactSpectrumCatalogueSource.url}
        />
      </aside>

      <main class="s2-main">
        <section class="s2-hero" aria-labelledby="page-title">
          <h1 id="page-title">Solid Spectrum</h1>
          <p>
            A component-by-component parity harness for React Spectrum S2 and
            @proyecto-viviana/solid-spectrum.
          </p>
        </section>

        <CatalogueOverviewMount
          entriesWithCoverage={entriesWithCoverage}
          missingOfficialCount={missingOfficialCount}
          officialCount={officialCount}
          overallCoverage={overallCoverage}
          strictStateCount={strictStateCount}
          visualEvidenceStateCount={visualEvidenceStateCount}
          liveCount={liveCount}
        />
      </main>

      <aside class="s2-toc" aria-label="On this page">
        <DocsTocMount
          sourceLabel="S2 source"
          sourceUrl={reactSpectrumCatalogueSource.url}
          variant="index"
        />
      </aside>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
    </script>
  </body>
</html>

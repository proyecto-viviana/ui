---
// Ported by hand from vendor/s2-docs/pages/ColorSwatchPicker.mdx (upstream: react-spectrum,
// Apache-2.0). Prose is upstream-verbatim; code blocks are copied with the docs-tooling
// highlight/PROPS markers stripped. The upstream InlineAlert is rendered as a lead-in note
// (not a gated heading). Gated by `report:parity --slug=colorswatchpicker`.
import { Code } from "astro:components";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import PropTable from "@comparison/components/PropTable.astro";
import ParityDisclosure from "@comparison/components/ParityDisclosure.astro";
import PortingNote from "@comparison/components/PortingNote.astro";
import { getComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsTypographyH1,
  docsTypographyH2,
  docsTypographyH3,
  docsTypographyP,
  docsTypographyPageDescription,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import { getTextWidth } from "@comparison/components/solid/chrome/textWidth";

const slug = "colorswatchpicker";
const entry = getComparisonEntry(slug);
const h1Class = staticClassName(docsTypographyH1);
const h2Class = staticClassName(docsTypographyH2);
const h3Class = staticClassName(docsTypographyH3);
const pClass = staticClassName(docsTypographyP);
const descClass = staticClassName(docsTypographyPageDescription);
const title = "ColorSwatchPicker";
const widthPerEm = getTextWidth(title);
const toc = [
  { href: "#value", label: "Value", depth: 2 },
  { href: "#api", label: "API", depth: 2 },
  { href: "#api-colorswatchpicker", label: "ColorSwatchPicker", depth: 3 },
];

const valueCode = `"use client";
import {ColorSwatchPicker, ColorSwatch, parseColor} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};
import {useState} from 'react';

function Example() {
  let [value, setValue] = useState(parseColor('#e11d48'));

  return (
    <>
      <ColorSwatchPicker value={value} onChange={setValue}>
        <ColorSwatch color="#e11d48" />
        <ColorSwatch color="#f97316" />
        <ColorSwatch color="#eab308" />
        <ColorSwatch color="#22c55e" />
        <ColorSwatch color="#3b82f6" />
        <ColorSwatch color="#8b5cf6" />
        <ColorSwatch color="#ec4899" />
      </ColorSwatchPicker>
      <pre className={style({font: 'body'})}>Selected color: {value.toString('rgb')}</pre>
    </>
  );
}`;

const anatomyCode = `<ColorSwatchPicker>
  <ColorSwatch />
</ColorSwatchPicker>`;
---

<DocsPageLayout
  reactSpectrumUrl={entry?.docsUrl}
  sidebarActiveSlug={slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry?.docsUrl}
  title={`${title} | Solid Spectrum`}
  tocItems={toc}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry?.docsUrl}
  tocVariant="page"
>
  <h1 id="colorswatchpicker" class={h1Class} style={`--width-per-em: ${widthPerEm}`}>{title}</h1>
  <p class={descClass}>
    A ColorSwatchPicker displays a list of color swatches and allows a user to select one of them.
  </p>

  {entry && <ComponentExampleSectionMount entry={entry} />}

  <h2 id="value" class={h2Class}>Value</h2>
  <p class={pClass}>
    Use the <code>value</code> or <code>defaultValue</code> prop to set the selected color, and
    <code>onChange</code> to handle selection changes. The value may be a string or <code>Color</code>
    object, parsed using the <code>parseColor</code> function.
  </p>
  <Code code={valueCode} lang="tsx" theme="github-dark" />
  <p class={pClass}>
    <strong>Color swatches must be unique:</strong> Equivalent colors in different color spaces are
    considered duplicates. For example, the values <code>#f00</code>, <code>hsl(0, 100%, 50%)</code>,
    and <code>hsb(0, 100%, 100%)</code> are all the same color. This is required for predictable
    selection behavior.
  </p>

  <h2 id="api" class={h2Class}>API</h2>
  <Code code={anatomyCode} lang="tsx" theme="github-dark" />

  <h3 id="api-colorswatchpicker" class={h3Class}>ColorSwatchPicker</h3>
  <PropTable source="ColorSwatchPicker" />

  <PortingNote component={slug} />

  <ParityDisclosure slug={slug} />
</DocsPageLayout>

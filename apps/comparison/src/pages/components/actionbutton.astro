---
// Ported by hand from vendor/s2-docs/pages/ActionButton.mdx (upstream: react-spectrum,
// Apache-2.0). Prose is upstream-verbatim; code blocks are copied with the
// docs-tooling highlight markers stripped. Gated by `report:parity --slug=actionbutton`.
import { Code } from "astro:components";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import PropTable from "@comparison/components/PropTable.astro";
import ParityDisclosure from "@comparison/components/ParityDisclosure.astro";
import PortingNote from "@comparison/components/PortingNote.astro";
import { getComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsTypographyH1,
  docsTypographyH2,
  docsTypographyH3,
  docsTypographyP,
  docsTypographyPageDescription,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import { getTextWidth } from "@comparison/components/solid/chrome/textWidth";

const slug = "actionbutton";
const entry = getComparisonEntry(slug);
const h1Class = staticClassName(docsTypographyH1);
const h2Class = staticClassName(docsTypographyH2);
const h3Class = staticClassName(docsTypographyH3);
const pClass = staticClassName(docsTypographyP);
const descClass = staticClassName(docsTypographyPageDescription);
const title = "ActionButton";
const widthPerEm = getTextWidth(title);
const toc = [
  { href: "#events", label: "Events", depth: 2 },
  { href: "#pending", label: "Pending", depth: 2 },
  { href: "#api", label: "API", depth: 2 },
  { href: "#api-actionbutton", label: "ActionButton", depth: 3 },
];

const eventsCode = `"use client";
import {ActionButton} from '@react-spectrum/s2';
import {useState} from 'react';

function Example() {
  let [count, setCount] = useState(0);

  return (
    <ActionButton onPress={() => setCount(c => c + 1)}>
      {count} Edits
    </ActionButton>
  );
}`;

const pendingCode = `"use client";
import {ActionButton} from '@react-spectrum/s2';
import {useState} from 'react';

function PendingButton() {
  let [isPending, setPending] = useState(false);

  return (
    <ActionButton
      isPending={isPending}
      onPress={() => {
        setPending(true);
        setTimeout(() => {
          setPending(false);
        }, 5000);
      }}>
      Save
    </ActionButton>
  );
}`;

const anatomyCode = `<ActionButton>
  <Icon /> or <Avatar />
  <Text />
  <NotificationBadge />
</ActionButton>`;
---

<DocsPageLayout
  reactSpectrumUrl={entry?.docsUrl}
  sidebarActiveSlug={slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry?.docsUrl}
  title={`${title} | Solid Spectrum`}
  tocItems={toc}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry?.docsUrl}
  tocVariant="page"
>
  <h1 id="actionbutton" class={h1Class} style={`--width-per-em: ${widthPerEm}`}>{title}</h1>
  <p class={descClass}>
    ActionButtons allow users to perform an action. They're used for similar, task-based options
    within a workflow, and are ideal for interfaces where buttons aren't meant to draw a lot of
    attention.
  </p>

  {entry && <ComponentExampleSectionMount entry={entry} />}

  <h2 id="events" class={h2Class}>Events</h2>
  <p class={pClass}>
    Use the <code>onPress</code> prop to handle interactions via mouse, keyboard, and touch. The
    <code>onPressStart</code>, <code>onPressEnd</code>, and <code>onPressChange</code> events are
    also emitted as the user interacts with the button.
  </p>
  <Code code={eventsCode} lang="tsx" theme="github-dark" />

  <h2 id="pending" class={h2Class}>Pending</h2>
  <p class={pClass}>
    Use the <code>isPending</code> prop to display a pending state. Pending buttons remain
    focusable, but are otherwise disabled. After a 1 second delay, an indeterminate spinner will be
    displayed in place of the button label and icon.
  </p>
  <Code code={pendingCode} lang="tsx" theme="github-dark" />

  <h2 id="api" class={h2Class}>API</h2>
  <Code code={anatomyCode} lang="tsx" theme="github-dark" />

  <h3 id="api-actionbutton" class={h3Class}>ActionButton</h3>
  <PropTable component={slug} />

  <PortingNote component={slug} />

  <ParityDisclosure slug={slug} />
</DocsPageLayout>

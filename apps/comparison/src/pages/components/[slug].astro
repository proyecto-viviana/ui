---
import ReactMount from "../../components/ReactMount.astro";
import SolidMount from "../../components/SolidMount.astro";
import ComponentExampleControlsMount from "@comparison/components/ComponentExampleControlsMount.astro";
import ComponentDetailHeroMount from "@comparison/components/ComponentDetailHeroMount.astro";
import { getComponentControlGroup } from "@comparison/data/component-controls";
import { comparisonEntries, type ComparisonEntry, type ComparisonLayerId } from "@comparison/data/comparison-manifest";
import ComponentDetailMetaMount from "@comparison/components/ComponentDetailMetaMount.astro";
import DocsSidebarMount from "@comparison/components/DocsSidebarMount.astro";
import DocsTocMount from "@comparison/components/DocsTocMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import "@comparison/styles/global.css";

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ComparisonEntry };
const controlGroup = getComponentControlGroup(entry);
const playgroundLayer: ComparisonLayerId = "styled";
const playgroundTrack = entry.layers[playgroundLayer];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{entry.title} | Solid Spectrum</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <DocsTopBarMount reactSpectrumUrl={entry.docsUrl} />

    <div class="s2-layout">
      <aside class="s2-sidebar">
        <DocsSidebarMount
          activeSlug={entry.slug}
          navigationLabel="Components"
          referenceLabel="S2 docs"
          referenceUrl={entry.docsUrl}
        />
      </aside>

      <main class="s2-main">
        <ComponentDetailHeroMount entry={entry} />

        <section class="s2-example" id="example" aria-labelledby="example-title">
          <div class="s2-example-preview">
            <div class="s2-comparison-frame">
              <article class="s2-framework-panel" data-framework="react">
                <header>
                  <span>React</span>
                  <strong>React Spectrum S2</strong>
                  <em>{playgroundTrack.react}</em>
                </header>
                {playgroundTrack.react === "live" ? (
                  <ReactMount componentSlug={entry.slug} layer={playgroundLayer} />
                ) : (
                  <div class="s2-empty-state">
                    {playgroundTrack.react === "missing"
                      ? "React reference is missing."
                      : "React reference is tracked but not wired yet."}
                  </div>
                )}
              </article>

              <article class="s2-framework-panel" data-framework="solid">
                <header>
                  <span>Solid</span>
                  <strong>solid-spectrum</strong>
                  <em>{playgroundTrack.solid}</em>
                </header>
                {playgroundTrack.solid === "live" ? (
                  <SolidMount componentSlug={entry.slug} layer={playgroundLayer} />
                ) : (
                  <div class="s2-empty-state">
                    {playgroundTrack.solid === "missing"
                      ? "Solid implementation is missing."
                      : "Solid implementation is tracked but not wired yet."}
                  </div>
                )}
              </article>
            </div>
            <p class="s2-example-note">{controlGroup.note}</p>
          </div>

          <div class="s2-example-controls">
            <ComponentExampleControlsMount entry={entry} />
          </div>
        </section>

        <ComponentDetailMetaMount entry={entry} />
      </main>

      <aside class="s2-toc" aria-label="On this page">
        <DocsTocMount
          entry={entry}
          sourceLabel="S2 source"
          sourceUrl={entry.docsUrl}
          variant="component"
        />
      </aside>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
      import "@comparison/scripts/component-controls";
    </script>
  </body>
</html>

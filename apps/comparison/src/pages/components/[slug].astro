---
import ComponentExampleControlsMount from "@comparison/components/ComponentExampleControlsMount.astro";
import ComponentExamplePreviewMount from "@comparison/components/ComponentExamplePreviewMount.astro";
import ComponentDetailHeroMount from "@comparison/components/ComponentDetailHeroMount.astro";
import { comparisonEntries, type ComparisonEntry } from "@comparison/data/comparison-manifest";
import ComponentDetailMetaMount from "@comparison/components/ComponentDetailMetaMount.astro";
import DocsSidebarMount from "@comparison/components/DocsSidebarMount.astro";
import DocsTocMount from "@comparison/components/DocsTocMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import "@comparison/styles/global.css";

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ComparisonEntry };
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{entry.title} | Solid Spectrum</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <DocsTopBarMount reactSpectrumUrl={entry.docsUrl} />

    <div class="s2-layout">
      <aside class="s2-sidebar">
        <DocsSidebarMount
          activeSlug={entry.slug}
          navigationLabel="Components"
          referenceLabel="S2 docs"
          referenceUrl={entry.docsUrl}
        />
      </aside>

      <main class="s2-main">
        <ComponentDetailHeroMount entry={entry} />

        <section class="s2-example" id="example" aria-labelledby="example-title">
          <div class="s2-example-preview">
            <ComponentExamplePreviewMount entry={entry} />
          </div>

          <div class="s2-example-controls">
            <ComponentExampleControlsMount entry={entry} />
          </div>
        </section>

        <ComponentDetailMetaMount entry={entry} />
      </main>

      <aside class="s2-toc" aria-label="On this page">
        <DocsTocMount
          entry={entry}
          sourceLabel="S2 source"
          sourceUrl={entry.docsUrl}
          variant="component"
        />
      </aside>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
      import "@comparison/scripts/component-controls";
    </script>
  </body>
</html>

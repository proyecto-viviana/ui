---
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import ComponentDetailHeroMount from "@comparison/components/ComponentDetailHeroMount.astro";
import { comparisonEntries, type ComparisonEntry } from "@comparison/data/comparison-manifest";
import ComponentDetailMetaMount from "@comparison/components/ComponentDetailMetaMount.astro";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";

export function getStaticPaths() {
  return comparisonEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: ComparisonEntry };
---

<DocsPageLayout
  reactSpectrumUrl={entry.docsUrl}
  sidebarActiveSlug={entry.slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry.docsUrl}
  title={`${entry.title} | Solid Spectrum`}
  tocEntry={entry}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry.docsUrl}
  tocVariant="component"
>
  <ComponentDetailHeroMount entry={entry} />

  <ComponentExampleSectionMount entry={entry} />

  <ComponentDetailMetaMount entry={entry} />
</DocsPageLayout>

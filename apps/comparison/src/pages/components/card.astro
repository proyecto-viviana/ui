---
// Ported by hand from vendor/s2-docs/pages/Card.mdx (upstream: react-spectrum,
// Apache-2.0). Prose is upstream-verbatim; code blocks are copied with the docs-tooling
// highlight/PROPS markers stripped, long Unsplash tracking params trimmed (consistent with
// the Image page), and the upstream `</CardView>` anatomy typo corrected to `</CardPreview>`.
// The Asset ExampleSwitcher (Image/Illustration) renders as two sequential code blocks.
// Gated by `report:parity --slug=card`.
import { Code } from "astro:components";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import PropTable from "@comparison/components/PropTable.astro";
import ParityDisclosure from "@comparison/components/ParityDisclosure.astro";
import PortingNote from "@comparison/components/PortingNote.astro";
import { getComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsTypographyH1,
  docsTypographyH2,
  docsTypographyH3,
  docsTypographyP,
  docsTypographyPageDescription,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import { getTextWidth } from "@comparison/components/solid/chrome/textWidth";

const slug = "card";
const entry = getComparisonEntry(slug);
const h1Class = staticClassName(docsTypographyH1);
const h2Class = staticClassName(docsTypographyH2);
const h3Class = staticClassName(docsTypographyH3);
const pClass = staticClassName(docsTypographyP);
const descClass = staticClassName(docsTypographyPageDescription);
const title = "Card";
const widthPerEm = getTextWidth(title);
const toc = [
  { href: "#content", label: "Content", depth: 2 },
  { href: "#asset", label: "Asset", depth: 3 },
  { href: "#user", label: "User", depth: 3 },
  { href: "#product", label: "Product", depth: 3 },
  { href: "#collection", label: "Collection", depth: 3 },
  { href: "#gallery", label: "Gallery", depth: 3 },
  { href: "#custom", label: "Custom", depth: 3 },
  { href: "#skeleton", label: "Skeleton", depth: 2 },
  { href: "#api", label: "API", depth: 2 },
  { href: "#api-card", label: "Card", depth: 3 },
  { href: "#api-assetcard", label: "AssetCard", depth: 3 },
  { href: "#api-usercard", label: "UserCard", depth: 3 },
  { href: "#api-productcard", label: "ProductCard", depth: 3 },
];

const assetImageCode = `"use client";
import {AssetCard, CardPreview, Image, Content, Text, ActionMenu, MenuItem} from '@react-spectrum/s2';

<AssetCard>
  <CardPreview>
    <Image src="https://images.unsplash.com/photo-1705034598432-1694e203cdf3?q=80&w=600&auto=format&fit=crop" />
  </CardPreview>
  <Content>
    <Text slot="title">Desert Sunset</Text>
    <ActionMenu>
      <MenuItem>Edit</MenuItem>
      <MenuItem>Share</MenuItem>
      <MenuItem>Delete</MenuItem>
    </ActionMenu>
    <Text slot="description">PNG • 2/3/2024</Text>
  </Content>
</AssetCard>`;

const assetIllustrationCode = `"use client";
import {AssetCard, CardPreview, Content, Text, ActionMenu, MenuItem} from '@react-spectrum/s2';
import FolderGradient from '@react-spectrum/s2/illustrations/gradient/generic2/FolderClose';

<AssetCard>
  <CardPreview>
    <FolderGradient />
  </CardPreview>
  <Content>
    <Text slot="title">Projects</Text>
    <ActionMenu>
      <MenuItem>Edit</MenuItem>
      <MenuItem>Share</MenuItem>
      <MenuItem>Delete</MenuItem>
    </ActionMenu>
    <Text slot="description">10 items • 6/14/2024</Text>
  </Content>
</AssetCard>`;

const userCode = `"use client";
import {UserCard, CardPreview, Image, Avatar, Content, Text, Footer, StatusLight} from '@react-spectrum/s2';
import preview from 'url:./assets/preview.png';

<UserCard>
  <CardPreview>
    <Image src={preview} />
  </CardPreview>
  <Avatar src="https://i.imgur.com/xIe7Wlb.png" />
  <Content>
    <Text slot="title">Simone Carter</Text>
    <Text slot="description">Art Director at Luma Creative Studios. Visual storyteller and coffee enthusiast.</Text>
  </Content>
  <Footer>
    <StatusLight size="S" variant="positive">Available</StatusLight>
  </Footer>
</UserCard>`;

const productCode = `"use client";
import {ProductCard, CardPreview, Image, Content, Text, Footer, Button} from '@react-spectrum/s2';
import preview from 'url:./assets/preview.png';
import logo from 'url:./assets/logo.svg';

<ProductCard>
  <CardPreview>
    <Image slot="preview" src={preview} />
  </CardPreview>
  <Image slot="thumbnail" src={logo} />
  <Content>
    <Text slot="title">Command + R</Text>
    <Text slot="description">Your all-in-one shortcut for apps, automations, and devices.</Text>
  </Content>
  <Footer>
    <Button variant="primary">Buy now</Button>
  </Footer>
</ProductCard>`;

const collectionCode = `"use client";
import {Card, CollectionCardPreview, Image, Content, Text} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};
import Folder from '@react-spectrum/s2/icons/Folder';

<Card>
  <CollectionCardPreview>
    <Image alt="" src="https://images.unsplash.com/photo-1705034598432-1694e203cdf3?q=80&w=600&auto=format&fit=crop" />
    <Image alt="" src="https://images.unsplash.com/photo-1722233987129-61dc344db8b6?q=80&w=600&auto=format&fit=crop" />
    <Image alt="" src="https://images.unsplash.com/photo-1722172118908-1a97c312ce8c?q=80&w=600&auto=format&fit=crop" />
    <Image alt="" src="https://images.unsplash.com/photo-1718378037953-ab21bf2cf771?q=80&w=600&auto=format&fit=crop" />
  </CollectionCardPreview>
  <Content>
    <Text slot="title">Travel</Text>
    <div className={style({gridColumnEnd: 'span 2', display: 'flex', alignItems: 'center', gap: 8})}>
      <Folder />
      <Text slot="description">20 photos</Text>
    </div>
  </Content>
</Card>`;

const galleryCode = `"use client";
import {Card, CardPreview, Image, Badge, Avatar} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};

<Card>
  <CardPreview>
    <Image
      alt="Narrow mountain trail with green grass and sharp peaks in the background"
      src="https://images.unsplash.com/photo-1722233987129-61dc344db8b6?q=80&w=600&auto=format&fit=crop"
      styles={style({width: 'full', aspectRatio: 'square', objectFit: 'cover', pointerEvents: 'none'})} />
    <Badge
      variant="yellow"
      styles={style({
        position: 'absolute',
        top: 16,
        insetEnd: 16
      })}>
      Free
    </Badge>
    <Avatar
      src="https://i.imgur.com/xIe7Wlb.png"
      size={24}
      isOverBackground
      styles={style({
        position: 'absolute',
        bottom: 16,
        insetStart: 16
      })} />
  </CardPreview>
</Card>`;

const customCode = `"use client";
import {Card, CardPreview, Image, Content, Text} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};
import Select from '@react-spectrum/s2/icons/Select';

<Card>
  <CardPreview>
    <Image
      alt=""
      src="https://images.unsplash.com/photo-1671225137978-aa9a19071b9a?q=80&w=600&auto=format&fit=crop" />
  </CardPreview>
  <Content>
    <div className={style({display: 'flex', alignItems: 'center', justifyContent: 'space-between'})}>
      <div className={style({display: 'flex', alignItems: 'center', gap: 4})}>
        <Select />
        <Text slot="description">Click through rate</Text>
      </div>
      <div className={style({display: 'flex', flexDirection: 'column'})}>
        <Text styles={style({font: 'title-xl'})}>1.012%</Text>
        <Text styles={style({font: 'ui-sm', color: 'positive-900'})}>21% ↑ average</Text>
      </div>
    </div>
  </Content>
</Card>`;

const skeletonCode = `"use client";
import {Skeleton, Card, CardPreview, Image, Content, Text} from '@react-spectrum/s2';

<Skeleton isLoading>
  <Card>
    <CardPreview>
      <Image src="https://images.unsplash.com/photo-1705034598432-1694e203cdf3?q=80&w=600&auto=format&fit=crop" />
    </CardPreview>
    <Content>
      <Text slot="title">Placeholder title</Text>
      <Text slot="description">This is placeholder content approximating the length of the real content to avoid layout shifting when the real content appears.</Text>
    </Content>
  </Card>
</Skeleton>`;

const cardAnatomy = `<Card>
  <CardPreview>
    <Image /> or <Illustration />
  </CardPreview>
  <Content>
    <Text slot="title" />
    <ActionMenu />
    <Text slot="description" />
  </Content>
  <Footer />
</Card>`;

const assetCardAnatomy = `<AssetCard>
  <CardPreview>
    <Image /> or <Illustration />
  </CardPreview>
  <Content>
    <Text slot="title" />
    <ActionMenu />
    <Text slot="description" />
  </Content>
</AssetCard>`;

const userCardAnatomy = `<UserCard>
  <CardPreview>
    <Image />
  </CardPreview>
  <Avatar />
  <Content>
    <Text slot="title" />
    <ActionMenu />
    <Text slot="description" />
  </Content>
  <Footer />
</UserCard>`;

const productCardAnatomy = `<ProductCard>
  <CardPreview>
    <Image slot="preview" />
  </CardPreview>
  <Image slot="thumbnail" />
  <Content>
    <Text slot="title" />
    <ActionMenu />
    <Text slot="description" />
  </Content>
  <Footer>
    <Button /> or <LinkButton />
  </Footer>
</ProductCard>`;
---

<DocsPageLayout
  reactSpectrumUrl={entry?.docsUrl}
  sidebarActiveSlug={slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry?.docsUrl}
  title={`${title} | Solid Spectrum`}
  tocItems={toc}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry?.docsUrl}
  tocVariant="page"
>
  <h1 id="card" class={h1Class} style={`--width-per-em: ${widthPerEm}`}>{title}</h1>
  <p class={descClass}>A Card summarizes an object that a user can select or navigate to.</p>

  {entry && <ComponentExampleSectionMount entry={entry} />}

  <h2 id="content" class={h2Class}>Content</h2>
  <p class={pClass}>
    Cards are flexible containers that represent objects a user can select or navigate to. Most cards
    include a preview, metadata, and an optional footer. Spectrum includes several pre-defined card
    components with layouts for specific use cases, or you can combine these sections to create custom
    cards.
  </p>

  <h3 id="asset" class={h3Class}>Asset</h3>
  <p class={pClass}>
    A <code>AssetCard</code> represents an asset such as an image, video, document, or folder. The
    <code>CardPreview</code> can contain either an <code>Image</code> or illustration. By default,
    images are displayed in a square preview without cropping. Add metadata in the
    <code>Content</code> section using the <code>title</code> and <code>description</code> slots.
  </p>
  <Code code={assetImageCode} lang="tsx" theme="github-dark" />
  <Code code={assetIllustrationCode} lang="tsx" theme="github-dark" />

  <h3 id="user" class={h3Class}>User</h3>
  <p class={pClass}>
    A <code>UserCard</code> represents a user profile. It includes an Avatar and a
    <code>Content</code> section with <code>title</code> and <code>description</code> slots, along
    with an optional header image and <code>Footer</code>.
  </p>
  <Code code={userCode} lang="tsx" theme="github-dark" />

  <h3 id="product" class={h3Class}>Product</h3>
  <p class={pClass}>
    A <code>ProductCard</code> represents a product a user can take action on. It has a a thumbnail
    image and a <code>Content</code> section with <code>title</code> and <code>description</code>
    slots, a <code>Footer</code> containing a call to action, and an optional header image.
  </p>
  <Code code={productCode} lang="tsx" theme="github-dark" />

  <h3 id="collection" class={h3Class}>Collection</h3>
  <p class={pClass}>
    A <code>CollectionCardPreview</code> displays up to 4 images in a collection of assets. When 4
    images are provided, the first one is displayed as a larger hero image.
  </p>
  <Code code={collectionCode} lang="tsx" theme="github-dark" />

  <h3 id="gallery" class={h3Class}>Gallery</h3>
  <p class={pClass}>
    A card can omit its <code>Content</code> section and display only a preview to create a gallery
    card typically seen in a waterfall layout. Ensure that the preview image has <code>alt</code>
    text, and any content placed above the preview has enough contrast against the background.
  </p>
  <Code code={galleryCode} lang="tsx" theme="github-dark" />

  <h3 id="custom" class={h3Class}>Custom</h3>
  <p class={pClass}>
    Combine the <code>CardPreview</code>, <code>Content</code>, and <code>Footer</code> components to
    create custom cards. Add additional elements and styles within these sections to create custom
    layouts as needed.
  </p>
  <Code code={customCode} lang="tsx" theme="github-dark" />

  <h2 id="skeleton" class={h2Class}>Skeleton</h2>
  <p class={pClass}>
    Wrap a card in a Skeleton to display a loading state. Placeholder text content and images are
    displayed in a skeleton style.
  </p>
  <Code code={skeletonCode} lang="tsx" theme="github-dark" />

  <h2 id="api" class={h2Class}>API</h2>

  <h3 id="api-card" class={h3Class}>Card</h3>
  <Code code={cardAnatomy} lang="tsx" theme="github-dark" />
  <PropTable source="Card" />

  <h3 id="api-assetcard" class={h3Class}>AssetCard</h3>
  <Code code={assetCardAnatomy} lang="tsx" theme="github-dark" />
  <PropTable source="AssetCard" />

  <h3 id="api-usercard" class={h3Class}>UserCard</h3>
  <Code code={userCardAnatomy} lang="tsx" theme="github-dark" />
  <PropTable source="UserCard" />

  <h3 id="api-productcard" class={h3Class}>ProductCard</h3>
  <Code code={productCardAnatomy} lang="tsx" theme="github-dark" />
  <PropTable source="ProductCard" />

  <PortingNote component={slug} />

  <ParityDisclosure slug={slug} />
</DocsPageLayout>

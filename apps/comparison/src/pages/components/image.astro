---
// Ported by hand from vendor/s2-docs/pages/Image.mdx (upstream: react-spectrum,
// Apache-2.0). Prose is upstream-verbatim; code blocks are copied with the
// docs-tooling highlight/PROPS markers stripped. Gated by `report:parity --slug=image`.
import { Code } from "astro:components";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import PropTable from "@comparison/components/PropTable.astro";
import ParityDisclosure from "@comparison/components/ParityDisclosure.astro";
import PortingNote from "@comparison/components/PortingNote.astro";
import { getComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsTypographyH1,
  docsTypographyH2,
  docsTypographyP,
  docsTypographyPageDescription,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import { getTextWidth } from "@comparison/components/solid/chrome/textWidth";

const slug = "image";
const entry = getComparisonEntry(slug);
const h1Class = staticClassName(docsTypographyH1);
const h2Class = staticClassName(docsTypographyH2);
const pClass = staticClassName(docsTypographyP);
const descClass = staticClassName(docsTypographyPageDescription);
const title = "Image";
const widthPerEm = getTextWidth(title);
const toc = [
  { href: "#conditional-sources", label: "Conditional sources", depth: 2 },
  { href: "#error-state", label: "Error state", depth: 2 },
  { href: "#imagecoordinator", label: "ImageCoordinator", depth: 2 },
  { href: "#api", label: "API", depth: 2 },
];

const conditionalCode = `"use client";
import {Image, Provider} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};

<Provider>
  <Image
    src={[
      {colorScheme: 'light', srcSet: 'https://images.unsplash.com/photo-1722172118908-1a97c312ce8c?q=80&w=600&auto=format&fit=crop'},
      {colorScheme: 'dark', srcSet: 'https://images.unsplash.com/photo-1722233987129-61dc344db8b6?q=80&w=600&auto=format&fit=crop'}
    ]}
    alt="Conditional image"
    styles={style({height: 300, maxWidth: 'full', borderRadius: 'default'})} />
</Provider>`;

const errorCode = `"use client";
import {Image} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};
import ErrorIcon from '@react-spectrum/s2/illustrations/linear/AlertNotice';

<Image
  src=""
  alt="Error image"
  styles={style({width: 400, maxWidth: 'full', height: 200, borderRadius: 'default'})}
  renderError={() => (
    <div className={style({display: 'flex', flexDirection: 'column', gap: 8, alignItems: 'center', justifyContent: 'center', height: 'full'})}>
      <ErrorIcon />
      <span className={style({font: 'body'})}>Error loading image</span>
    </div>
  )} />`;

const coordinatorCode = `"use client";
import {ImageCoordinator, Image} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};

<ImageCoordinator>
  <div
    className={style({
      display: 'grid',
      gridTemplateColumns: 'repeat(auto-fit, minmax(140px, 1fr))',
      gridTemplateRows: [180],
      gap: 8
    })}>
    <Image alt="" src="https://images.unsplash.com/photo-1705034598432-1694e203cdf3?q=80&w=600&auto=format&fit=crop" styles={style({objectFit: 'cover', borderRadius: 'sm'})} />
    <Image alt="" src="https://images.unsplash.com/photo-1722233987129-61dc344db8b6?q=80&w=600&auto=format&fit=crop" styles={style({objectFit: 'cover', borderRadius: 'sm'})} />
    <Image alt="" src="https://images.unsplash.com/photo-1722172118908-1a97c312ce8c?q=80&w=600&auto=format&fit=crop" styles={style({objectFit: 'cover', borderRadius: 'sm'})} />
    <Image alt="" src="https://images.unsplash.com/photo-1718378037953-ab21bf2cf771?q=80&w=600&auto=format&fit=crop" styles={style({objectFit: 'cover', borderRadius: 'sm'})} />
  </div>
</ImageCoordinator>`;
---

<DocsPageLayout
  reactSpectrumUrl={entry?.docsUrl}
  sidebarActiveSlug={slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry?.docsUrl}
  title={`${title} | Solid Spectrum`}
  tocItems={toc}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry?.docsUrl}
  tocVariant="page"
>
  <h1 id="image" class={h1Class} style={`--width-per-em: ${widthPerEm}`}>{title}</h1>
  <p class={descClass}>An image with support for skeleton loading and custom error states.</p>

  {entry && <ComponentExampleSectionMount entry={entry} />}

  <h2 id="conditional-sources" class={h2Class}>Conditional sources</h2>
  <p class={pClass}>
    Set the <code>src</code> prop to an array of objects describing conditional images, e.g. media
    queries or image formats. These accept the same props as the <code>{"<source>"}</code> HTML
    element, as well as <code>colorScheme</code> to conditionally render images based on the Provider
    color scheme.
  </p>
  <Code code={conditionalCode} lang="tsx" theme="github-dark" />

  <h2 id="error-state" class={h2Class}>Error state</h2>
  <p class={pClass}>
    Use <code>renderError</code> to display a custom error UI when an image fails to load.
  </p>
  <Code code={errorCode} lang="tsx" theme="github-dark" />

  <h2 id="imagecoordinator" class={h2Class}>ImageCoordinator</h2>
  <p class={pClass}>
    An <code>ImageCoordinator</code> coordinates loading behavior for a group of images. Images
    within an ImageCoordinator are revealed together once all of them have loaded.
  </p>
  <Code code={coordinatorCode} lang="tsx" theme="github-dark" />

  <h2 id="api" class={h2Class}>API</h2>
  <PropTable component={slug} />

  <PortingNote component={slug} />

  <ParityDisclosure slug={slug} />
</DocsPageLayout>

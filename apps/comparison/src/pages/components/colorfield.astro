---
// Ported by hand from vendor/s2-docs/pages/ColorField.mdx (upstream: react-spectrum,
// Apache-2.0). Prose is upstream-verbatim; code blocks are copied with the
// docs-tooling highlight/PROPS markers stripped. Gated by `report:parity --slug=colorfield`.
import { Code } from "astro:components";
import DocsPageLayout from "@comparison/layouts/DocsPageLayout.astro";
import ComponentExampleSectionMount from "@comparison/components/ComponentExampleSectionMount.astro";
import PropTable from "@comparison/components/PropTable.astro";
import ParityDisclosure from "@comparison/components/ParityDisclosure.astro";
import PortingNote from "@comparison/components/PortingNote.astro";
import { getComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsTypographyH1,
  docsTypographyH2,
  docsTypographyP,
  docsTypographyPageDescription,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import { getTextWidth } from "@comparison/components/solid/chrome/textWidth";

const slug = "colorfield";
const entry = getComparisonEntry(slug);
const h1Class = staticClassName(docsTypographyH1);
const h2Class = staticClassName(docsTypographyH2);
const pClass = staticClassName(docsTypographyP);
const descClass = staticClassName(docsTypographyPageDescription);
const title = "ColorField";
const widthPerEm = getTextWidth(title);
const toc = [
  { href: "#value", label: "Value", depth: 2 },
  { href: "#channel", label: "Channel", depth: 2 },
  { href: "#forms", label: "Forms", depth: 2 },
  { href: "#api", label: "API", depth: 2 },
];

const valueCode = `"use client";
import {ColorField, type Color} from '@react-spectrum/s2';
import {useState} from 'react';
import {parseColor} from '@react-stately/color';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};

function Example() {
  let [value, setValue] = useState<Color | null>(parseColor('#e73623'));

  return (
    <div>
      <ColorField
        label="Primary color"
        placeholder="Enter a color"
        value={value}
        onChange={setValue} />
      <pre className={style({font: 'body'})}>Current value: {value?.toString('hex')}</pre>
    </div>
  );
}`;

const channelCode = `"use client";
import {ColorField, parseColor, type Color} from '@react-spectrum/s2';
import {style} from '@react-spectrum/s2/style' with {type: 'macro'};
import {useState} from 'react';

function Example() {
  let [color, setColor] = useState<Color | null>(parseColor('#7f007f'));

  return (
    <div className={style({ display: 'flex', flexDirection: 'column', gap: 8 })}>
      <ColorField
        label="Hue"
        placeholder="Select a hue"
        value={color}
        onChange={setColor}
        colorSpace="hsl"
        channel="hue" />
      <ColorField
        label="Saturation"
        placeholder="Select a saturation"
        value={color}
        onChange={setColor}
        colorSpace="hsl"
        channel="saturation" />
      <ColorField
        label="Lightness"
        placeholder="Select a lightness"
        value={color}
        onChange={setColor}
        colorSpace="hsl"
        channel="lightness" />
      <pre className={style({font: 'body'})}>Current value: {color?.toString('hex')}</pre>
    </div>
  );
}`;

const formsCode = `"use client";
import {ColorField, Button, Form} from '@react-spectrum/s2';

function Example(props) {
  return (
    <Form>
      <ColorField
        {...props}
        label="Brand color"
        placeholder="Enter a color"
        name="brandColor"
      />
      <Button type="submit">Submit</Button>
    </Form>
  );
}`;
---

<DocsPageLayout
  reactSpectrumUrl={entry?.docsUrl}
  sidebarActiveSlug={slug}
  sidebarNavigationLabel="Components"
  sidebarReferenceLabel="S2 docs"
  sidebarReferenceUrl={entry?.docsUrl}
  title={`${title} | Solid Spectrum`}
  tocItems={toc}
  tocSourceLabel="S2 source"
  tocSourceUrl={entry?.docsUrl}
  tocVariant="page"
>
  <h1 id="colorfield" class={h1Class} style={`--width-per-em: ${widthPerEm}`}>{title}</h1>
  <p class={descClass}>
    A color field allows users to edit a hex color or individual color channel value.
  </p>

  {entry && <ComponentExampleSectionMount entry={entry} />}

  <h2 id="value" class={h2Class}>Value</h2>
  <p class={pClass}>
    Use the <code>value</code> or <code>defaultValue</code> prop to set the color value, and
    <code>onChange</code> to handle user input. The value may be a string or <code>Color</code>
    object, parsed using the <code>parseColor</code> function. <code>onChange</code> is always called
    with a <code>Color</code> object.
  </p>
  <Code code={valueCode} lang="tsx" theme="github-dark" />

  <h2 id="channel" class={h2Class}>Channel</h2>
  <p class={pClass}>
    By default, ColorField displays a hex value. Set the <code>colorSpace</code> and
    <code>channel</code> props to display a specific color channel.
  </p>
  <Code code={channelCode} lang="tsx" theme="github-dark" />

  <h2 id="forms" class={h2Class}>Forms</h2>
  <p class={pClass}>
    Use the <code>name</code> prop to submit the text value to the server. Set the
    <code>isRequired</code> prop to validate the value, or implement custom client or server-side
    validation. See the Forms guide to learn more.
  </p>
  <Code code={formsCode} lang="tsx" theme="github-dark" />

  <h2 id="api" class={h2Class}>API</h2>
  <PropTable component={slug} />

  <PortingNote component={slug} />

  <ParityDisclosure slug={slug} />
</DocsPageLayout>

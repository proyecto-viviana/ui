---
import DocsFooterMount from "@comparison/components/DocsFooterMount.astro";
import DocsSidebarMount from "@comparison/components/DocsSidebarMount.astro";
import DocsTocMount from "@comparison/components/DocsTocMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";
import {
  docsArticleColumn,
  docsArticleContent,
  docsLayoutRoot,
  docsMainContent,
  docsSidebarRail,
  docsTocRail,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import "@comparison/styles/global.css";

type DocsTocVariant = "index" | "component";

export interface Props {
  reactSpectrumUrl?: string;
  sidebarActiveSlug?: string;
  sidebarNavigationLabel?: string;
  sidebarReferenceLabel?: string;
  sidebarReferenceUrl?: string;
  title: string;
  tocEntry?: ComparisonEntry;
  tocSourceLabel?: string;
  tocSourceUrl?: string;
  tocVariant: DocsTocVariant;
}

const {
  reactSpectrumUrl,
  sidebarActiveSlug,
  sidebarNavigationLabel,
  sidebarReferenceLabel,
  sidebarReferenceUrl,
  title,
  tocEntry,
  tocSourceLabel,
  tocSourceUrl,
  tocVariant,
} = Astro.props;
const layoutRootClass = staticClassName(docsLayoutRoot);
const sidebarRailClass = staticClassName(docsSidebarRail);
const mainContentClass = staticClassName(docsMainContent);
const articleColumnClass = staticClassName(docsArticleColumn);
const articleContentClass = staticClassName(docsArticleContent);
const tocRailClass = staticClassName(docsTocRail);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <DocsTopBarMount
      activeSlug={sidebarActiveSlug}
      navigationLabel={sidebarNavigationLabel}
      reactSpectrumUrl={reactSpectrumUrl}
      referenceLabel={sidebarReferenceLabel}
      referenceUrl={sidebarReferenceUrl}
      tocSlug={tocEntry?.slug}
      tocVariant={tocVariant}
    />

    <div class:list={["s2-layout", layoutRootClass]}>
      <aside class:list={["s2-sidebar", sidebarRailClass]}>
        <DocsSidebarMount
          activeSlug={sidebarActiveSlug}
          navigationLabel={sidebarNavigationLabel}
          referenceLabel={sidebarReferenceLabel}
          referenceUrl={sidebarReferenceUrl}
        />
      </aside>

      <main class:list={["s2-main", mainContentClass]}>
        <div class:list={["s2-article-column", articleColumnClass]}>
          <article class:list={["s2-article", articleContentClass]}>
            <slot />
          </article>
          <DocsFooterMount />
        </div>

        <aside class:list={["s2-docs-toc-rail", tocRailClass]} aria-label="On this page">
          <DocsTocMount
            entry={tocEntry}
            sourceLabel={tocSourceLabel}
            sourceUrl={tocSourceUrl}
            variant={tocVariant}
          />
        </aside>
      </main>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
    </script>
  </body>
</html>

---
import DocsFooterMount from "@comparison/components/DocsFooterMount.astro";
import DocsSidebarMount from "@comparison/components/DocsSidebarMount.astro";
import DocsTocMount from "@comparison/components/DocsTocMount.astro";
import DocsTopBarMount from "@comparison/components/DocsTopBarMount.astro";
import type { ComparisonEntry } from "@comparison/data/comparison-manifest";
import type { DocsTocItem, DocsTocVariant } from "@comparison/data/docs-toc";
import {
  docsArticleColumn,
  docsArticleContent,
  docsLayoutRoot,
  docsMainContent,
  docsSidebarRail,
  docsTocRail,
  staticClassName,
} from "@comparison/components/solid/chrome/styles";
import "@comparison/styles/global.css";

export interface Props {
  reactSpectrumUrl?: string;
  sidebarActiveSlug?: string;
  sidebarNavigationLabel?: string;
  sidebarReferenceLabel?: string;
  sidebarReferenceUrl?: string;
  title: string;
  tocEntry?: ComparisonEntry;
  tocItems?: DocsTocItem[];
  tocSourceLabel?: string;
  tocSourceUrl?: string;
  tocVariant: DocsTocVariant;
}

const {
  reactSpectrumUrl,
  sidebarActiveSlug,
  sidebarNavigationLabel,
  sidebarReferenceLabel,
  sidebarReferenceUrl,
  title,
  tocEntry,
  tocItems,
  tocSourceLabel,
  tocSourceUrl,
  tocVariant,
} = Astro.props;
const layoutRootClass = staticClassName(docsLayoutRoot);
const sidebarRailClass = staticClassName(docsSidebarRail);
const mainContentClass = staticClassName(docsMainContent);
const articleColumnClass = staticClassName(docsArticleColumn);
const articleContentClass = staticClassName(docsArticleContent);
const tocRailClass = staticClassName(docsTocRail);
const s2PrimaryFontPreloadUrl =
  "https://use.typekit.net/af/ca4cba/0000000000000000775c55a1/31/l?primer=f592e0a4b9356877842506ce344308576437e4f677d7c9b78ca2162e6cad991a&fvd=n1&v=3";
---

<html lang="en" data-theme="system" data-resolved-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href={s2PrimaryFontPreloadUrl}
    />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = "solid-spectrum-theme";
        const isThemeChoice = (value) =>
          value === "system" || value === "light" || value === "dark";

        let theme = "system";

        try {
          const savedTheme = window.localStorage.getItem(storageKey);

          if (isThemeChoice(savedTheme)) {
            theme = savedTheme;
          }
        } catch {
          theme = "system";
        }

        const resolvedTheme =
          theme === "light" || theme === "dark"
            ? theme
            : window.matchMedia?.("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        root.dataset.theme = theme;
        root.dataset.resolvedTheme = resolvedTheme;
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="comparison-app s2-docs" data-theme="system" data-resolved-theme="light">
    <script is:inline>
      (() => {
        const root = document.body;
        const theme = document.documentElement.dataset.theme || "system";
        const resolvedTheme = document.documentElement.dataset.resolvedTheme || "light";
        root.dataset.theme = theme;
        root.dataset.resolvedTheme = resolvedTheme;
      })();
    </script>

    <DocsTopBarMount
      activeSlug={sidebarActiveSlug}
      navigationLabel={sidebarNavigationLabel}
      reactSpectrumUrl={reactSpectrumUrl}
      referenceLabel={sidebarReferenceLabel}
      referenceUrl={sidebarReferenceUrl}
      tocItems={tocItems}
      tocSlug={tocEntry?.slug}
      tocVariant={tocVariant}
    />

    <div class:list={["s2-layout", layoutRootClass]}>
      <aside class:list={["s2-sidebar", sidebarRailClass]}>
        <DocsSidebarMount
          activeSlug={sidebarActiveSlug}
          navigationLabel={sidebarNavigationLabel}
          referenceLabel={sidebarReferenceLabel}
          referenceUrl={sidebarReferenceUrl}
        />
      </aside>

      <main class:list={["s2-main", mainContentClass]}>
        <div class:list={["s2-article-column", articleColumnClass]}>
          <article class:list={["s2-article", articleContentClass]}>
            <slot />
          </article>
          <DocsFooterMount />
        </div>

        <aside class:list={["s2-docs-toc-rail", tocRailClass]} aria-label="On this page">
          <DocsTocMount
            entry={tocEntry}
            items={tocItems}
            sourceLabel={tocSourceLabel}
            sourceUrl={tocSourceUrl}
            variant={tocVariant}
          />
        </aside>
      </main>
    </div>

    <script>
      import "@comparison/scripts/docs-theme";
      import "@comparison/scripts/docs-heading-anchors";
    </script>
  </body>
</html>
